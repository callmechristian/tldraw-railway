{
	"name": "@tldraw/railway-server-example",
	"description": "tldraw infinite canvas SDK (Railway server example).",
	"version": "0.0.0",
	"private": true,
	"author": {
		"name": "tldraw GB Ltd.",
		"email": "hello@tldraw.com"
	},
	"license": "MIT",
	"main": "./src/server/server.ts",
	"scripts": {
		"dev": "concurrently -n server,client -c red,blue \"yarn dev-server\" \"yarn dev-client\"",
		"dev-server": "yarn run -T tsx watch ./src/server/server.ts",
		"dev-client": "vite dev --host",
		"build:server": "yarn run -T esbuild src/server/server.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/server.cjs --external:better-sqlite3 --sourcemap",
		"build:client": "vite build",
		"build": "yarn build:server && yarn build:client",
		"start": "node dist/server.cjs",
		"test-ci": "echo 'No tests yet'",
		"test": "yarn run -T vitest run --passWithNoTests",
		"test-coverage": "lazy inherit",
		"lint": "yarn run -T tsx ../../internal/scripts/lint.ts"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.12",
		"@types/express": "^4.17.21",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"concurrently": "^9.1.2",
		"lazyrepo": "0.0.0-alpha.27",
		"tsx": "^4.19.2",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"@fastify/cors": "^10.0.0",
		"@fastify/websocket": "^11.0.0",
		"@tldraw/sync": "^5.2.5",
		"@tldraw/sync-core": "^5.2.5",
		"@vitejs/plugin-react": "^6.0.1",
		"better-sqlite3": "^12.10.0",
		"fastify": "^5.8.1",
		"itty-router": "^5.0.18",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"react-router-dom": "^6.28.2",
		"tldraw": "^5.2.5",
		"unfurl.js": "^6.4.0",
		"vite": "^8.0.16",
		"ws": "^8.18.0"
	}
}
